<h1>Gestión de usuarios</h1>

<table border="1">
<tr>
  <th>ID</th>
  <th>Usuario</th>
  <th>Rol</th>
  <th>Acciones</th>
</tr>

<% users.forEach(user => { %>

<tr>
  <td><%= user.id %></td>
  <td><%= user.username %></td>

  <td>
    <form action="/admin/users/<%= user.id %>/role" method="POST">
      <select name="role">
        <option value="user" <%= user.role === "user" ? "selected" : "" %>>user</option>
        <option value="admin" <%= user.role === "admin" ? "selected" : "" %>>admin</option>
      </select>
      <button type="submit">Guardar</button>
    </form>
  </td>

  <td>
    <form action="/admin/users/<%= user.id %>/delete" method="POST" onsubmit="return confirm('¿Eliminar usuario?')">
      <button type="submit">Eliminar</button>
    </form>
  </td>
</tr>

<% }) %>

</table>